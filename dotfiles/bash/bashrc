random_char() {
    echo -n "${CHARS:RANDOM % ${#CHARS}:1}"
}

setcolor() {
    # Restablecer colores si no hay argumentos
    if [ -z "$1" ]; then
        echo -n "$(tput sgr0)"
        return 0
    fi
    # Validar que los argumentos sean nГєmeros
    if ! [[ "$1" =~ ^[0-9]+$ ]]; then
        echo "Error: El primer argumento debe ser un nГєmero (color de texto)." >&2
        return -1
    fi

    echo -n "$(tput setaf "$1")"

    if [ -n "$2" ]; then
        if ! [[ "$2" =~ ^[0-9]+$ ]]; then
            echo "Error: El segundo argumento debe ser un nГєmero (color de fondo)." >&2
            return -1
        fi
        echo -n "$(tput setab "$2")"
    fi
}


build_prompt() {
    local on_git_repo="$(git rev-parse --is-inside-work-tree 2> /dev/null)"
    local git_branch
    [[ "$on_git_repo" == "true" ]] &&
        git_branch=$(git rev-parse --abbrev-ref HEAD 2> /dev/null)

    local prompt=""
    prompt+="\[$(setcolor 255)\]оЂ‡\[$(setcolor 0)\]оѓЉ \[$(setcolor 4 0)\] пЊѓ  "

    if [[ "$on_git_repo" == "true" ]]; then
        prompt+="\[$(setcolor 0 202)\]о‚ґ"
        prompt+="\[$(setcolor 0 202)\] ${git_branch} "
        prompt+="\[$(setcolor 202 4)\]о‚°"
    else
        prompt+="\[$(setcolor 0 4)\]о‚ґ"
    fi

    prompt+="\[$(setcolor 0 4)\] $(random_char)  \\W \[$(setcolor)\]\[$(setcolor 4)\]о‚ґ \[$(setcolor)\]"

    PS1="${prompt}"
}

PROMPT_COMMAND=build_prompt

